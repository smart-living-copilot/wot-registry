FROM python:3.12-slim AS production

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY backend /app/backend
RUN pip install --no-cache-dir /app/backend

ENV PYTHONPATH=/app/backend/src

COPY docker/entrypoint-registry.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV REDIS_URL=redis://valkey:6379 \
    REGISTRY_DATABASE_URL=sqlite:////data/registry/wot_registry.db \
    REGISTRY_PUBLIC_URL=http://localhost:8000 \
    WOT_RUNTIME_STREAM=wot_runtime_events

RUN mkdir -p /data/registry
VOLUME ["/data"]

EXPOSE 8000
ENTRYPOINT ["/entrypoint.sh"]
